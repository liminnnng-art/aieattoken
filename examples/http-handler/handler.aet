@User{Name:string;Email:string;Age:int};@UserStore{mu:rw;users:map[string]User};NewUserStore()->*UserStore{^&UserStore{users:make(map[string]User)}};UserStore.Get(name)->(User,error){s.mu.RLock();defer s.mu.RUnlock();user,ok:=s.users[name];if !ok{^User{},Ef("user not found: %s",name)};^user,nil};UserStore.Set(user:User){s.mu.Lock();defer s.mu.Unlock();s.users[user.Name]=user};UserStore.HandleGet(w,r){name:=r.URL.Query().Get("name");if name==""{He(w,"name required",400);^};user:=s.Get(name)?;w.Header().Set("Content-Type","application/json");Je(w).Encode(user)};main(){store:=NewUserStore();store.Set(User{Name:"Alice",Email:"alice@example.com",Age:30});hf("/user",store.HandleGet);pl("Server starting on :8080");hl(":8080",nil)}