!py-v1;class CalculatorError(Exception){};@dc Calculator{result=0;history=fi(default_factory=list);apply(operator,operand){prev=.result;match operator{case "+"{.result+=operand};case "-"{.result-=operand};case "*"{.result*=operand};case "/"{if operand==0{raise CalculatorError("Division by zero")};.result/=operand};case "**"{.result**=operand};case _{raise CalculatorError(f"Unknown operator: {operator!r}")}};.history.append(f"{prev} {operator} {operand} = {.result}");^.result};reset(){.result=0;.history.clear()};show_history(){if not .history{print("(no history)");^};for i,entry in enumerate(.history,1){print(f"  {i}. {entry}")}}};repl(){calc=Calculator();print("Calculator  (type 'q' to quit, 'h' for history, 'c' to clear)");print(f"  = {calc.result}");while True{try{line=input("> ").strip()}except (EOFError,KeyboardInterrupt){print();break};if not line{continue};if line.lower()=="q"{break};if line.lower()=="h"{calc.show_history();continue};if line.lower()=="c"{calc.reset();print(f"  = {calc.result}");continue};parts=line.split(maxsplit=1);if len(parts)!=2{print("  Error: enter <operator> <number>  (e.g. + 5)");continue};(op,raw_value)=parts;try{value=float(raw_value)}except ValueError{print(f"  Error: invalid number: {raw_value!r}");continue};try{result=calc.apply(op,value);print(f"  = {result}")}except CalculatorError as exc{print(f"  Error: {exc}")}}};@main{repl()}