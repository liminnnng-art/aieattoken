!py-v1;class Color(Enum){RED;GREEN;BLUE;YELLOW;BLACK;hex_code(){mapping={Color.RED:"#FF0000",Color.GREEN:"#00FF00",Color.BLUE:"#0000FF",Color.YELLOW:"#FFFF00",Color.BLACK:"#000000"};^mapping.get(self,"#FFFFFF")}};class Shape(ABC){slots(_color,_label);_instance_count=0;init(color=Color.BLACK,label=""){._color=color;._label=label;Shape._instance_count+=1};@property color(){^._color};@color.setter color(value){if not isi(value,Color){raise TypeError(f"Expected Color, got {type(value).__name__}")};._color=value};@property label(){^._label or f"{type(self).__name__}_{id(self)%10000}"};@abstractmethod area(){...};@abstractmethod perimeter(){...};@classmethod total_instances(){^cls._instance_count};@staticmethod is_valid_dimension(value){^isi(value,(int,float)) and value>0};repr(){^f"{type(self).__name__}(color={._color.name}, label={.label!r})"}};class Circle(Shape){slots(_radius);init(radius,color=Color.RED,label=""){sup().__init__(color,label);if not .is_valid_dimension(radius){raise ValueError(f"Invalid radius: {radius}")};._radius=radius};@property radius(){^._radius};area(){^mpi*._radius**2};perimeter(){^2*mpi*._radius};@classmethod unit_circle(){^cls(radius=1,label="unit_circle")}};class Rectangle(Shape){slots(_width,_height);init(width,height,color=Color.BLUE,label=""){sup().__init__(color,label);if not (.is_valid_dimension(width) and .is_valid_dimension(height)){raise ValueError(f"Invalid dimensions: {width}x{height}")};._width=width;._height=height};@property width(){^._width};@property height(){^._height};@property is_square(){^mic(._width,._height)};area(){^._width*._height};perimeter(){^2*(._width+._height)};diagonal(){^mh(._width,._height)};@classmethod square(side,**kwargs){^cls(side,side,**kwargs)}};@dc ShapeCollection{name:str;shapes=fi(default_factory=list);add(shape){.shapes.append(shape)};total_area(){^sum((s.area() for s in .shapes))};total_perimeter(){^sum((s.perimeter() for s in .shapes))};filter_by_color(color){^[s for s in .shapes if s.color==color]};filter_by_type(shape_type){^[s for s in .shapes if isi(s,shape_type)]};largest(){if not .shapes{^None}^max(.shapes,key=|s|s.area())};sorted_by_area(reverse=False){^sorted(.shapes,key=|s|s.area(),reverse=reverse)};iter(){^iter(.shapes)};ln(){^len(.shapes)};summary(){lines=[f"Collection: {.name} ({len(self)} shapes)",f"  Total area:      {.total_area():.4f}",f"  Total perimeter:  {.total_perimeter():.4f}"];if big:=.largest() is not None{lines.append(f"  Largest:          {big!r} (area={big.area():.4f})")}^"\n".join(lines)}};@main{collection=ShapeCollection(name="demo");collection.add(Circle(5,color=Color.RED,label="big_circle"));collection.add(Circle.unit_circle());collection.add(Rectangle(3,4,color=Color.GREEN));collection.add(Rectangle.square(2.5,color=Color.BLUE,label="my_square"));collection.add(Circle(2,color=Color.YELLOW));print(collection.summary());print();print("Shapes sorted by area (descending):");for shape in collection.sorted_by_area(reverse=True){print(f"  {shape!r}  area={shape.area():.4f}")};print(f"
Red shapes: {collection.filter_by_color(Color.RED)}");print(f"Circles:    {collection.filter_by_type(Circle)}");print(f"Total Shape instances created: {Shape.total_instances()}")}