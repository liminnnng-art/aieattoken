!py-v1;class HttpStatus(IntEnum){OK=200;CREATED=201;BAD_REQUEST=400;NOT_FOUND=404;METHOD_NOT_ALLOWED=405;INTERNAL_ERROR=500};@dc class Request{method:str;path:str;headers=fi(default_factory=dict);body=None;json(){if .body is None{raise ValueError("Request body is empty")};^jl(.body)}};@dc class Response{status=HttpStatus.OK;body="";headers=fi(default_factory=||{"Content-Type":"application/json"});@staticmethod json_response(data,status=HttpStatus.OK){^Response(status=status,body=jd(data,default=str))};@staticmethod error(message,status=HttpStatus.BAD_REQUEST){^Response.json_response({"error":message},status=status)}};@dc class User{id:int;name:str;email:str;created_at="";to_dict(){^asdict(self)}};RouteHandler=Callable[([Request],Response)];require_json(func){@functools.wraps(func) wrapper(request){content_type=request.headers.get("Content-Type","");if "application/json" not in content_type and request.method in ("POST","PUT"){^Response.error("Content-Type must be application/json",HttpStatus.BAD_REQUEST)};^func(request)};^wrapper};log_request(func){@functools.wraps(func) wrapper(request){start=time.monotonic();response=func(request);elapsed=(time.monotonic()-start)*1000;print(f"{request.method} {request.path} -> {response.status} ({elapsed:.1f}ms)");^response};^wrapper};class Router{init(){._routes={}};route(path,methods=None){allowed=methods or ["GET"];decorator(func){for method in allowed{._routes[(method.upper(),path)]=func};^func};^decorator};dispatch(request){handler=._routes.get((request.method,request.path));if handler is None{any_path=any((p==request.path for (_,p) in ._routes));if any_path{^Response.error("Method not allowed",HttpStatus.METHOD_NOT_ALLOWED)};^Response.error("Not found",HttpStatus.NOT_FOUND)};try{^handler(request)}except json.JSONDecodeError{^Response.error("Invalid JSON in request body")}except Exception as exc{^Response.error(f"Internal error: {exc}",HttpStatus.INTERNAL_ERROR)}}};app=Router();_users_db={};_next_id=1;@app.route("/users",methods=["GET"]) @log_request list_users(request){users=[u.to_dict() for u in _users_db.values()];^Response.json_response(users)};@app.route("/users",methods=["POST"]) @log_request @require_json create_user(request){global _next_id;data=request.json();name=data.get("name");email=data.get("email");if not name or not email{^Response.error("Fields 'name' and 'email' are required")};user=User(id=_next_id,name=name,email=email,created_at=time.strftime("%Y-%m-%dT%H:%M:%S"));_users_db[user.id]=user;_next_id+=1;^Response.json_response(user.to_dict(),status=HttpStatus.CREATED)};@app.route("/health",methods=["GET"]) health_check(request){^Response.json_response({"status":"ok","users_count":len(_users_db)})};@main{print("--- Health check ---");resp=app.dispatch(Request(method="GET",path="/health"));print(resp.body);print("\n--- Create user ---");resp=app.dispatch(Request(method="POST",path="/users",headers={"Content-Type":"application/json"},body=jd({"name":"Alice","email":"alice@example.com"})));print(resp.body);print("\n--- List users ---");resp=app.dispatch(Request(method="GET",path="/users"));print(resp.body);print("\n--- Not found ---");resp=app.dispatch(Request(method="GET",path="/missing"));print(resp.body)}