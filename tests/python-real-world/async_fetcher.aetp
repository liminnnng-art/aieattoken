!py-v1;class FetchStatus(Enum){SUCCESS=auto();TIMEOUT=auto();ERROR=auto();RETRIED=auto()};@dataclass(frozen=True) class FetchResult{url:str;status_code:int;body:Optional[str];elapsed_ms:float;fetch_status:FetchStatus;attempt=1;@property ok(){^200<=.status_code and .status_code<300};json(){if .body is None{raise ValueError("Response body is empty")};^jl(.body)}};@dc class FetchStats{total=0;succeeded=0;failed=0;retried=0;total_time_ms=0;@property avg_time_ms(){^.total_time_ms/.total if .total>0 else 0};record(result){.total+=1;.total_time_ms+=result.elapsed_ms;if result.ok{.succeeded+=1}else{.failed+=1};if result.attempt>1{.retried+=1}};summary(){^f"Fetched {.total} URLs: {.succeeded} ok, {.failed} failed, {.retried} retried | avg {.avg_time_ms:.1f}ms"}};class SimulatedConnection{init(base_delay=0.05){._base_delay=base_delay;._open=False};async aenter(){await asl(0.01);._open=True;^self};async aexit(exc_type,exc_val,exc_tb){._open=False};async request(url){if not ._open{raise RuntimeError("Connection is not open")};delay=._base_delay+random.uniform(0.01,0.1);await asl(delay);roll=random.random();if roll<0.1{raise TimeoutError(f"Request to {url} timed out")};if roll<0.15{^(500,jd({"error":"Internal server error"}))};body=jd({"url":url,"data":f"response_for_{url.split('/')[-1]}","timestamp":time.time()});^(200,body)}};async fetch_one(conn,url,semaphore,max_retries=3){async with semaphore{last_error=None;for attempt in range(1,max_retries+1){start=time.monotonic();try{(status_code,body)=await conn.request(url);elapsed=(time.monotonic()-start)*1000;fetch_status=FetchStatus.SUCCESS if 200<=status_code and status_code<300 else FetchStatus.ERROR;if attempt>1{fetch_status=FetchStatus.RETRIED};^FetchResult(url=url,status_code=status_code,body=body,elapsed_ms=round(elapsed,2),fetch_status=fetch_status,attempt=attempt)}except TimeoutError as exc{elapsed=(time.monotonic()-start)*1000;last_error=str(exc);if attempt<max_retries{await asl(0.02*attempt)}}};^FetchResult(url=url,statu