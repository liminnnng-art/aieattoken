!go-v2;@Stack{items:[]int};NewStack()->*Stack{^&Stack{items:make([]int,0)}};Stack.Push(val:int){s.items=append(s.items,val)};Stack.Pop()->(int,error){if #s.items==0{^0,En("stack is empty")};val:=s.items[#s.items-1];s.items=s.items[:#s.items-1];^val,nil};Stack.Peek()->(int,error){if #s.items==0{^0,En("stack is empty")};^s.items[#s.items-1],nil};Stack.Size()->int{^#s.items};Stack.IsEmpty()->bool{^#s.items==0};main(){s:=NewStack();s.Push(10);s.Push(20);s.Push(30);pf("Size: %d\n",s.Size());val:=s.Pop()?;pf("Popped: %d\n",val);top:=s.Peek()?;pf("Top: %d\n",top);pf("Empty: %v\n",s.IsEmpty())}