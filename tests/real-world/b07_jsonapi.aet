!v3;@APIError{Code:int;Message:string};APIError.Error()->string{^sf("API error %d: %s",a.Code,a.Message)};@Pagination{Page:int;PerPage:int;Total:int;TotalPages:int};@APIResponse{Success:bool;Data:json.RawMessage;Error:*APIError;Pagination:*Pagination;Timestamp:string};NewSuccessResponse(data:_in{})->(*APIResponse,error){raw:=jm(data)?;^&APIResponse{Success:true,Data:raw,Timestamp:tn().UTC().Format(time.RFC3339)},nil};NewErrorResponse(code:int,message:string)->*APIResponse{^&APIResponse{Success:false,Error:&APIError{Code:code,Message:message},Timestamp:tn().UTC().Format(time.RFC3339)}};NewPaginatedResponse(data:_in{},page:int,perPage:int,total:int)->(*APIResponse,error){resp:=NewSuccessResponse(data)?;totalPages:=total/perPage;if total%perPage!=0{totalPages++};resp.Pagination=&Pagination{Page:page,PerPage:perPage,Total:total,TotalPages:totalPages};^resp,nil};APIResponse.ToJSON()->(string,error){data:=json.MarshalIndent(a,"","  ")?;^string(data),nil};@User{ID:int;Name:string;Email:string};fetchUsers(page:int)->(*APIResponse,error){if page<1{^nil,Ef("invalid page: %d",page)};users:=[]User{{ID:1,Name:"Alice",Email:"alice@example.com"},{ID:2,Name:"Bob",Email:"bob@example.com"}};resp:=NewPaginatedResponse(users,page,10,25)?;^resp,nil};main(){resp:=fetchUsers(1)?;output:=resp.ToJSON()?;pl(output);pl();errResp:=NewErrorResponse(404,"user not found");output,err:=errResp.ToJSON();if err!=nil{pl("JSON error:",err);^};pl(output)}