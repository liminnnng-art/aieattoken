!go-v2;@Record{Name:string;Age:int;Score:float64;Active:bool};parseCSV(data:string)->([]Record,error){reader:=csv.NewReader(strings.NewReader(data));rows:=reader.ReadAll()?;if #rows<2{^nil,Ef("csv must have header and at least one row")};header:=rows[0];nameIdx,ageIdx,scoreIdx,activeIdx:=-1,-1,-1,-1;for i,h:=range header{switch St(Sl(h)){case "name":nameIdx=i;case "age":ageIdx=i;case "score":scoreIdx=i;case "active":activeIdx=i}};if nameIdx==-1{^nil,Ef("missing 'name' column")};records:=make([]Record,0,#rows-1);for lineNum,row:=range rows[1:]{rec:=Record{};if nameIdx<#row{rec.Name=St(row[nameIdx])};if ageIdx>=0&&ageIdx<#row{age:=Ai(St(row[ageIdx]))?;rec.Age=age};if scoreIdx>=0&&scoreIdx<#row{score:=strconv.ParseFloat(St(row[scoreIdx]),64)?;rec.Score=score};if activeIdx>=0&&activeIdx<#row{rec.Active=St(Sl(row[activeIdx]))=="true"};_=lineNum;records+=rec};^records,nil};filterActive(records:[]Record)->[]Record{result:=make([]Record,0);for _,r:=range records{if r.Active{result+=r}};^result};sortByScore(records:[]Record)->[]Record{sorted:=make([]Record,#records);copy(sorted,records);So(sorted,func(i,j int)bool{^sorted[i].Score>sorted[j].Score});^sorted};averageScore(records:[]Record)->float64{if #records==0{^0};total:=0.0;for _,r:=range records{total+=r.Score};^total/float64(#records)};toCSV(records:[]Record)->(string,error){var buf strings.Builder;writer:=csv.NewWriter(&buf);writer.Write([]string{"name","age","score","active"})?;for _,r:=range records{row:=[]string{r.Name,ia(r.Age),strconv.FormatFloat(r.Score,'f',2,64),strconv.FormatBool(r.Active)};writer.Write(row)?};writer.Flush();if err:=writer.Error();err!=nil{^"",Ef("flush: %w",err)};^buf.String(),nil};main(){data:=`name,age,score,active
Alice,30,95.5,true
Bob,25,82.3,true
Charlie,35,71.0,false
Diana,28,91.2,true
Eve,33,88.7,false`;records:=parseCSV(data)?;pf("Total records: %d\n",#records);pf("Average score: %.2f\n",averageScore(records));active:=filterActive(records);pf("Active records: %d\n",#active);sorted:=sortByScore(records);pl("Top scorer:",sorted[0].Name);output:=toCSV(active)?;pl("Active records CSV:");pf("%s",output)}