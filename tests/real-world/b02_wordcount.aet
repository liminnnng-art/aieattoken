!v1;wordCount(text:string)->map[string]int{counts:=make(map[string]int);words:=strings.Fields(Sl(text));for _,w:=range words{w=strings.Trim(w,".,!?;:\"'()-");if w!=""{counts[w]++}};^counts};topWords(counts:map[string]int,n:int)->[]string{@wc{word:string;count:int};pairs:=make([]wc,0,len(counts));for w,c:=range counts{pairs=append(pairs,wc{w,c})};So(pairs,func(i,j int)bool{^pairs[i].count>pairs[j].count});result:=make([]string,0,n);for i:=0;i<n&&i<len(pairs);i++{result=append(result,sf("%s:%d",pairs[i].word,pairs[i].count))};^result};main(){text:="the quick brown fox jumps over the lazy dog the fox the dog";counts:=wordCount(text);pl("Word frequencies:");for w,c:=range counts{pf("  %s: %d\n",w,c)};pl("Top 3:",topWords(counts,3))}