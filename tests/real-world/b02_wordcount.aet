!v3;wordCount(text:string)->mp[string]int{counts:=mk(mp[string]int);words:=strings.Fields(Sl(text));for _,w:=rng words{w=strings.Trim(w,".,!?;:\"'()-");if w!=""{counts[w]++}};^counts};topWords(counts:mp[string]int,n:int)->[]string{@wc{word:string;count:int};pairs:=mk([]wc,0,ln(counts));for w,c:=rng counts{pairs=apl(pairs,wc{w,c})};So(pairs,fn(i,j int)bool{^pairs[i].count>pairs[j].count});result:=mk([]string,0,n);for i:=0;i<n&&i<ln(pairs);i++{result=apl(result,sf("%s:%d",pairs[i].word,pairs[i].count))};^result};main(){text:="the quick brown fox jumps over the lazy dog the fox the dog";counts:=wordCount(text);pl("Word frequencies:");for w,c:=rng counts{pf("  %s: %d\n",w,c)};pl("Top 3:",topWords(counts,3))}