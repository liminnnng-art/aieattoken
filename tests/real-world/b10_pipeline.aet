!v3;@DataPoint{ID:int;Value:float64;Timestamp:time.Time;Tags:[]string};@Result{ID:int;Original:float64;Processed:float64;Label:string};generate(count:int)-><-chan DataPoint{out:=mk(chan DataPoint);go fn(){defer close(out);for i:=0;i<count;i++{out<-DataPoint{ID:i,Value:float64(i)*1.5,Timestamp:tn(),Tags:[]string{"raw"}}}}();^out};flt(in:<-chan DataPoint,minVal:float64)-><-chan DataPoint{out:=mk(chan DataPoint);go fn(){defer close(out);for dp:=rng in{if dp.Value>=minVal{out<-dp}}}();^out};transform(in:<-chan DataPoint,fn:fn(float64)float64)-><-chan DataPoint{out:=mk(chan DataPoint);go fn(){defer close(out);for dp:=rng in{dp.Value=fn(dp.Value);dp.Tags=apl(dp.Tags,"transformed");out<-dp}}();^out};classify(in:<-chan DataPoint)-><-chan Result{out:=mk(chan Result);go fn(){defer close(out);for dp:=rng in{label:="low";if dp.Value>=10{label="medium"};if dp.Value>=50{label="high"};out<-Result{ID:dp.ID,Original:float64(dp.ID)*1.5,Processed:dp.Value,Label:label}}}();^out};fanOut(in:<-chan DataPoint,n:int)->[]<-chan DataPoint{outs:=mk([]<-chan DataPoint,n);chs:=mk([]chan DataPoint,n);for i:=0;i<n;i++{chs[i]=mk(chan DataPoint);outs[i]=chs[i]};go fn(){defer fn(){for _,ch:=rng chs{close(ch)}}();idx:=0;for dp:=rng in{chs[idx%n]<-dp;idx++}}();^outs};fanIn(channels:...<-chan Result)-><-chan Result{out:=mk(chan Result);var wg wg;for _,ch:=rng channels{wg.Add(1);go fn(c:<-chan Result){defer wg.Done();for r:=rng c{out<-r}}(ch)};go fn(){wg.Wait();close(out)}();^out};collect(in:<-chan Result)->[]Result{var results []Result;for r:=rng in{results=apl(results,r)};^results};summarize(results:[]Result){if ln(results)==0{pl("No results");^};counts:=mp[string]int{};totalProcessed:=0.0;for _,r:=rng results{counts[r.Label]++;totalProcessed+=r.Processed};pf("Total: %d results\n",ln(results));pf("Average processed value: %.2f\n",totalProcessed/float64(ln(results)));for label,count:=rng counts{pf("  %s: %d\n",label,count)}};RunPipeline(count:int,workers:int)->[]Result{source:=generate(count);filtered:=flt(source,5.0);branches:=fanOut(filtered,workers);resultChans:=mk([]<-chan Result,workers);for i,branch:=rng branches{transformed:=transform(branch,fn(v:float64)float64{^math.Sqrt(v)*10});resultChans[i]=classify(transformed)};merged:=fanIn(resultChans...);^collect(merged)};main(){start:=tn();results:=RunPipeline(100,4);elapsed:=Ts(start);summarize(results);pf("Pipeline completed in %v\n",elapsed)}