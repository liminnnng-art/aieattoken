!go-v2;findMax(nums:[]int)->(int,error){if #nums==0{^0,Ef("empty slice")};max:=nums[0];for _,n:=range nums{if n>max{max=n}};^max,nil};findMin(nums:[]int)->(int,error){if #nums==0{^0,Ef("empty slice")};min:=nums[0];for _,n:=range nums{if n<min{min=n}};^min,nil};findMaxMin(nums:[]int)->(int,int,error){max:=findMax(nums)?;min:=findMin(nums)?;^max,min,nil};main(){data:=[]int{3,1,4,1,5,9,2,6,5,3,5};max,min,err:=findMaxMin(data);if err!=nil{pl("Error:",err);^};pf("Max: %d, Min: %d\n",max,min)}