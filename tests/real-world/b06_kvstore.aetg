!go-v2;@Entry{Value:string;CreatedAt:time.Time;TTL:time.Duration};Entry.IsExpired()->bool{if e.TTL==0{^false};^Ts(e.CreatedAt)>e.TTL};@KVStore{mu:rw;data:map[string]Entry};NewKVStore()->*KVStore{^&KVStore{data:make(map[string]Entry)}};KVStore.Set(key:string,value:string){k.mu.Lock();defer k.mu.Unlock();k.data[key]=Entry{Value:value,CreatedAt:tn()}};KVStore.SetWithTTL(key:string,value:string,ttl:time.Duration){k.mu.Lock();defer k.mu.Unlock();k.data[key]=Entry{Value:value,CreatedAt:tn(),TTL:ttl}};KVStore.Get(key:string)->(string,error){k.mu.RLock();defer k.mu.RUnlock();entry,ok:=k.data[key];if !ok{^"",Ef("key not found: %s",key)};if entry.IsExpired(){^"",Ef("key expired: %s",key)};^entry.Value,nil};KVStore.Delete(key:string)->error{k.mu.Lock();defer k.mu.Unlock();if _,ok:=k.data[key];!ok{^Ef("key not found: %s",key)};delete(k.data,key);^nil};KVStore.Keys()->[]string{k.mu.RLock();defer k.mu.RUnlock();keys:=make([]string,0,#k.data);for kk,e:=range k.data{if !e.IsExpired(){keys+=kk}};^keys};KVStore.Len()->int{^len(k.Keys())};KVStore.Cleanup()->int{k.mu.Lock();defer k.mu.Unlock();removed:=0;for kk,e:=range k.data{if e.IsExpired(){delete(k.data,kk);removed++}};^removed};main(){store:=NewKVStore();store.Set("name","Alice");store.Set("role","admin");store.SetWithTTL("session","abc123",5*time.Second);val,err:=store.Get("name");if err!=nil{pl("Error:",err)}else{pf("name = %s\n",val)};pf("Keys: %v\n",store.Keys());pf("Count: %d\n",store.Len());err=store.Delete("role");if err!=nil{pl("Delete error:",err)};pf("After delete, keys: %v\n",store.Keys())}