!go-v2;@Temperature{Value:float64;Unit:string};Temperature.ToCelsius()->float64{switch t.Unit{case "F":^(t.Value-32)*5/9;case "K":^t.Value-273.15;default:^t.Value}};Temperature.ToFahrenheit()->float64{switch t.Unit{case "C":^t.Value*9/5+32;case "K":^(t.Value-273.15)*9/5+32;default:^t.Value}};Temperature.ToKelvin()->float64{switch t.Unit{case "C":^t.Value+273.15;case "F":^(t.Value-32)*5/9+273.15;default:^t.Value}};Temperature.String()->string{^sf("%.2f%s",t.Value,t.Unit)};main(){temps:=[]Temperature{{100,"C"},{212,"F"},{373.15,"K"}};for _,t:=range temps{pf("%s -> C=%.2f F=%.2f K=%.2f\n",t.String(),t.ToCelsius(),t.ToFahrenheit(),t.ToKelvin())}}