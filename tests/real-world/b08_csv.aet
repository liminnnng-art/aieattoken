!v3;@Record{Name:string;Age:int;Score:float64;Active:bool};parseCSV(data:string)->([]Record,error){reader:=csv.NewReader(strings.NewReader(data));rows:=reader.ReadAll()?;if ln(rows)<2{^nil,Ef("csv must have header and at least one row")};header:=rows[0];nameIdx,ageIdx,scoreIdx,activeIdx:=-1,-1,-1,-1;for i,h:=rng header{switch St(Sl(h)){case "name":nameIdx=i;case "age":ageIdx=i;case "score":scoreIdx=i;case "active":activeIdx=i}};if nameIdx==-1{^nil,Ef("missing 'name' column")};records:=mk([]Record,0,ln(rows)-1);for lineNum,row:=rng rows[1:]{rec:=Record{};if nameIdx<ln(row){rec.Name=St(row[nameIdx])};if ageIdx>=0&&ageIdx<ln(row){age:=Ai(St(row[ageIdx]))?;rec.Age=age};if scoreIdx>=0&&scoreIdx<ln(row){score:=strconv.ParseFloat(St(row[scoreIdx]),64)?;rec.Score=score};if activeIdx>=0&&activeIdx<ln(row){rec.Active=St(Sl(row[activeIdx]))=="true"};_=lineNum;records=apl(records,rec)};^records,nil};filterActive(records:[]Record)->[]Record{result:=mk([]Record,0);for _,r:=rng records{if r.Active{result=apl(result,r)}};^result};sortByScore(records:[]Record)->[]Record{sorted:=mk([]Record,ln(records));cpy(sorted,records);So(sorted,fn(i,j int)bool{^sorted[i].Score>sorted[j].Score});^sorted};averageScore(records:[]Record)->float64{if ln(records)==0{^0};total:=0.0;for _,r:=rng records{total+=r.Score};^total/float64(ln(records))};toCSV(records:[]Record)->(string,error){var buf strings.Builder;writer:=csv.NewWriter(&buf);writer.Write([]string{"name","age","score","active"})?;for _,r:=rng records{row:=[]string{r.Name,ia(r.Age),strconv.FormatFloat(r.Score,'f',2,64),strconv.FormatBool(r.Active)};writer.Write(row)?};writer.Flush();if err:=writer.Error();err!=nil{^"",Ef("flush: %w",err)};^buf.String(),nil};main(){data:=`name,age,score,active
Alice,30,95.5,true
Bob,25,82.3,true
Charlie,35,71.0,false
Diana,28,91.2,true
Eve,33,88.7,false`;records:=parseCSV(data)?;pf("Total records: %d\n",ln(records));pf("Average score: %.2f\n",averageScore(records));active:=filterActive(records);pf("Active records: %d\n",ln(active));sorted:=sortByScore(records);pl("Top scorer:",sorted[0].Name);output:=toCSV(active)?;pl("Active records CSV:");pf("%s",output)}