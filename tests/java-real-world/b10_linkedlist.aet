!v3;check(label:string,condition:bool){status:=_t(condition,"PASS","FAIL");pl("  "+label+": "+status);if (condition){passed++}else{failed++}};main(args:[]string){pl("=== Basic Operations ===");list:=DoublyLinkedList();check("New list is empty",list.isEmpty());check("New list size 0",list.size()==0);list.add(10);list.add(20);list.add(30);pl("  List: "+list);check("Size after adds",list.size()==3);check("Get 0",list.get(0)==10);check("Get 1",list.get(1)==20);check("Get 2",list.get(2)==30);check("First",list.getFirst()==10);check("Last",list.getLast()==30);pl("
=== AddFirst / AddAt ===");list.addFirst(5);pl("  After addFirst(5): "+list);check("AddFirst",list.getFirst()==5);check("Size",list.size()==4);list.addAt(2,15);pl("  After addAt(2, 15): "+list);check("AddAt index 2",list.get(2)==15);check("Size",list.size()==5);pl("
=== Set ===");old:=list.set(2,99);pl("  After set(2, 99): "+list);check("Set returns old value",old==15);check("Set new value",list.get(2)==99);pl("
=== Remove ===");list.set(2,15);removed:=list.removeAt(2);pl("  After removeAt(2): "+list);check("RemoveAt returns value",removed==15);check("Size after remove",list.size()==4);list.add(20);pl("  Before remove(20): "+list);check("Remove first 20",list.remove(20));pl("  After remove(20): "+list);check("Size after remove",list.size()==4);check("Second 20 still present",list.contains(20));pl("
=== IndexOf / Contains ===");slist:=DoublyLinkedList();slist.add("a");slist.add("b");slist.add("c");slist.add("b");slist.add("d");pl("  String list: "+slist);check("indexOf b",slist.indexOf("b")==1);check("lastIndexOf b",slist.lastIndexOf("b")==3);check("indexOf missing",slist.indexOf("z")==-1);check("Contains c",slist.contains("c"));check("Not contains z",!slist.contains("z"));pl("
=== RemoveAll ===");slist.add("b");pl("  Before removeAll(b): "+slist);removedCount:=slist.removeAll("b");pl("  After removeAll(b): "+slist);check("RemoveAll count",removedCount==3);check("No b remains",!slist.contains("b"));check("Size",slist.size()==3);pl("
=== Reverse ===");rlist:=DoublyLinkedList();rlist.add(1);rlist.add(2);rlist.add(3);rlist.add(4);rlist.add(5);pl("  Before reverse: "+rlist);rlist.reverse();pl("  After reverse: "+rlist);check("Reversed first",rlist.getFirst()==5);check("Reversed last",rlist.getLast()==1);check("Reversed order",rlist.get(0)==5&&rlist.get(1)==4&&rlist.get(2)==3);pl("
=== Iterator ===");forward:=Sb();for _,val:=rng rlist{forward.apd(val).apd(" ")};pl("  Forward: "+forward.function toString() { [native code] }().trim());check("Forward iteration",forward.function toString() { [native code] }().trim().equals("5 4 3 2 1"));backward:=Sb();rit:=rlist.reverseIterator();for (rit.hasNext()){backward.apd(rit.next()).apd(" ")};pl("  Backward: "+backward.function toString() { [native code] }().trim());check("Reverse iteration",backward.function toString() { [native code] }().trim().equals("1 2 3 4 5"));pl("
=== For-each with Enhanced For ===");words:=DoublyLinkedList();words.add("hello");words.add("world");sb:=Sb();for _,w:=rng words{sb.apd(w).apd(" ")};check("For-each works",sb.function toString() { [native code] }().trim().equals("hello world"));pl("
=== Edge Cases ===");elist:=DoublyLinkedList();try{elist.get(0);check("Get on empty throws",false)}catch(e:IndexOutOfBoundsException){check("Get on empty throws",true)};try{elist.getFirst();check("GetFirst on empty throws",false)}catch(e:NoSuchElementException){check("GetFirst on empty throws",true)};try{elist.removeAt(0);check("RemoveAt on empty throws",false)}catch(e:IndexOutOfBoundsException){check("RemoveAt on empty throws",true)};elist.add(42);check("Single element list",elist.size()==1&&elist.getFirst()==42&&elist.getLast()==42);elist.removeAt(0);check("Remove only element",elist.isEmpty());nlist:=DoublyLinkedList();nlist.add(nil);nlist.add("a");nlist.add(nil);check("Contains null",nlist.contains(nil));check("IndexOf null",nlist.indexOf(nil)==0);check("LastIndexOf null",nlist.lastIndexOf(nil)==2);check("Remove null",nlist.remove(nil));check("Size after removing null",nlist.size()==2);pl("
=== toArray ===");alist:=DoublyLinkedList();alist.add(10);alist.add(20);alist.add(30);arr:=alist.toArray();check("Array length",ln(arr)==3);check("Array values",int(arr[0])==10&&int(arr[1])==20&&int(arr[2])==30);pl("
=== Clear ===");alist.clear();check("Clear empties list",alist.isEmpty());check("Clear size 0",alist.size()==0);pf("%n=== Results: %d passed, %d failed ===%n",passed,failed)};var passed:int=0;var failed:int=0;@class DoublyLinkedList impl Iterable{head:Node;tail:Node;size:int;add(item:T){node:=Node(item);if (tail==nil){head=node}else{tail.next=node;node.prev=tail;tail=node};size++};addFirst(item:T){node:=Node(item);if (head==nil){head=node}else{node.next=head;head.prev=node;head=node};size++};addAt(index:int,item:T){if (index<0||index>size){panic(IndexOutOfBoundsException("Index: "+index))};if (index==0){addFirst(item);^};if (index==size){add(item);^};current:=getNode(index);node:=Node(item);node.prev=current.prev;node.next=current;current.prev.next=node;current.prev=node;size++};get(index:int)->T{^getNode(index).data};set(index:int,item:T)->T{node:=getNode(index);old:=node.data;node.data=item;^old};removeAt(index:int)->T{node:=getNode(index);^unlinkNode(node)};remove(item:T)->bool{current:=head;for (current!=nil){if (Objects.equals(current.data,item)){unlinkNode(current);^true};current=current.next};^false};removeAll(item:T)->int{count:=0;current:=head;for (current!=nil){next:=current.next;if (Objects.equals(current.data,item)){unlinkNode(current);count++};current=next};^count};unlinkNode(node:Node)->T{data:=node.data;if (node.prev!=nil){node.prev.next=node.next}else{head=node.next};if (node.next!=nil){node.next.prev=node.prev}else{tail=node.prev};size--;^data};getNode(index:int)->Node{if (index<0||index>=size){panic(IndexOutOfBoundsException("Index: "+index+", Size: "+size))};var current:Node;if (index<size/2){current=head;for i:=0;i<index;i++{current=current.next}}else{current=tail;for i:=size-1;i>index;i--{current=current.prev}};^current};indexOf(item:T)->int{current:=head;index:=0;for (current!=nil){if (Objects.equals(current.data,item)){^index};current=current.next;index++};^-1};lastIndexOf(item:T)->int{current:=tail;index:=size-1;for (current!=nil){if (Objects.equals(current.data,item)){^index};current=current.prev;index--};^-1};contains(item:T)->bool{^indexOf(item)>=0};size()->int{^size};isEmpty()->bool{^size==0};getFirst()->T{if (head==nil){panic(NoSuchElementException())};^head.data};getLast()->T{if (tail==nil){panic(NoSuchElementException())};^tail.data};reverse(){current:=head;var temp:Node;for (current!=nil){temp=current.next;current.next=current.prev;current.prev=temp;current=temp};temp=head;head=tail;tail=temp};clear(){head=nil;size=0};toArray()->[]_in{arr:=mk([]_in,size);current:=head;i:=0;for (current!=nil){arr[i]=current.data;current=current.next};^arr};iterator()->Iterator{^Iterator()};reverseIterator()->Iterator{^Iterator()};toString()->string{sj:=StringJoiner(", ","[","]");for _,item:=rng this{sj.add(Sv(item))};^sj.function toString() { [native code] }()};@class Node{data:T;prev:Node;next:Node;init(data:T){this.data=data}}}