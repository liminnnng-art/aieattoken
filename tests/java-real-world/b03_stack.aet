!v3;main(args:[]string){stack:=GenericStack();pl("Empty: "+(_t(stack.isEmpty(),"PASS","FAIL")));stack.push(10);stack.push(20);stack.push(30);pl("Size after 3 pushes: "+(_t(stack.size()==3,"PASS","FAIL")));pl("Peek: "+(_t(stack.peek()==30,"PASS","FAIL")));pl("Pop: "+(_t(stack.pop()==30,"PASS","FAIL")));pl("Pop: "+(_t(stack.pop()==20,"PASS","FAIL")));pl("Pop: "+(_t(stack.pop()==10,"PASS","FAIL")));pl("Empty after pops: "+(_t(stack.isEmpty(),"PASS","FAIL")));try{stack.pop();pl("Pop empty: FAIL")}catch(e:EmptyStackException){pl("Pop empty throws: PASS")};sStack:=GenericStack();sStack.push("hello");sStack.push("world");pl("String peek: "+(_t("world".equals(sStack.peek()),"PASS","FAIL")))};@class GenericStack{items:[]T;push(item:T){items.add(item)};pop()->T{if (isEmpty()){panic(EmptyStackException())};^items.remove(items.size()-1)};peek()->T{if (isEmpty()){panic(EmptyStackException())};^items.get(items.size()-1)};isEmpty()->bool{^items.isEmpty()};size()->int{^items.size()}}