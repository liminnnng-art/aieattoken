!v2;runTest(validator:Validator,label:string,input:T,expected:bool){result:=validator.isValid(input);status:=if((result==expected),"PASS","FAIL");detail:=if(result,"valid",validator.getErrorMessage(input));pf("  %-30s -> %-8s [%s] %s%n",input,detail,status,if(status.equals("FAIL"),"(expected "+expected+")",""))};main(args:[]string){emailV:=EmailValidator();phoneV:=PhoneValidator();passV:=PasswordValidator();pl("=== Email Validation ===");runTest(emailV,"email","user@example.com",true);runTest(emailV,"email","name.last+tag@domain.co.uk",true);runTest(emailV,"email","invalid@",false);runTest(emailV,"email","@domain.com",false);runTest(emailV,"email","no-at-sign.com",false);runTest(emailV,"email","",false);pl("
=== Phone Validation ===");runTest(phoneV,"phone","1234567890",true);runTest(phoneV,"phone","(123) 456-7890",true);runTest(phoneV,"phone","123-456-7890",true);runTest(phoneV,"phone","+1-234-567-8901",true);runTest(phoneV,"phone","12345",false);runTest(phoneV,"phone","abcdefghij",false);pl("
=== Password Validation ===");runTest(passV,"pass","Str0ng!Pass",true);runTest(passV,"pass","Ab1!xxxx",true);runTest(passV,"pass","weak",false);runTest(passV,"pass","alllowercase1!",false);runTest(passV,"pass","ALLUPPERCASE1!",false);runTest(passV,"pass","NoDigits!here",false);runTest(passV,"pass","NoSpecial1here",false)};@Validator[isValid(input:T)->bool;getErrorMessage(input:T)->string];@class EmailValidator impl Validator{EMAIL_PATTERN:Pattern;isValid(input:string)->bool{if (input==nil||input.isBlank()){^false};^EMAIL_PATTERN.matcher(input).matches()};getErrorMessage(input:string)->string{if (input==nil||input.isBlank()){^"Email cannot be empty"};if (!input.contains("@")){^"Email must contain @"};if (!EMAIL_PATTERN.matcher(input).matches()){^"Invalid email format"};^""}};@class PhoneValidator impl Validator{PHONE_PATTERN:Pattern;isValid(input:string)->bool{if (input==nil||input.isBlank()){^false};^PHONE_PATTERN.matcher(input.trim()).matches()};getErrorMessage(input:string)->string{if (input==nil||input.isBlank()){^"Phone number cannot be empty"};if (!PHONE_PATTERN.matcher(input.trim()).matches()){^"Invalid phone format"};^""}};@class PasswordValidator impl Validator{isValid(input:string)->bool{if (input==nil||len(input)<8){^false};hasUpper:=false;hasLower:=false;hasDigit:=false;hasSpecial:=false;for _,c:=range input.toCharArray(){if (Character.isUpperCase(c)){hasUpper=true}else if (Character.isLowerCase(c)){hasLower=true}else if (Character.isDigit(c)){hasDigit=true}else{hasSpecial=true}};^hasUpper&&hasLower&&hasDigit&&hasSpecial};getErrorMessage(input:string)->string{if (input==nil){^"Password cannot be null"};if (len(input)<8){^"Password must be at least 8 characters"};hasUpper:=false;hasLower:=false;hasDigit:=false;hasSpecial:=false;for _,c:=range input.toCharArray(){if (Character.isUpperCase(c)){hasUpper=true}else if (Character.isLowerCase(c)){hasLower=true}else if (Character.isDigit(c)){hasDigit=true}else{hasSpecial=true}};if (!hasUpper){^"Password must contain an uppercase letter"};if (!hasLower){^"Password must contain a lowercase letter"};if (!hasDigit){^"Password must contain a digit"};if (!hasSpecial){^"Password must contain a special character"};^""}}