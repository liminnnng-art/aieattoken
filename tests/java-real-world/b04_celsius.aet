!v2;approxEqual(a:float64,b:float64)->bool{^Ma(a-b)<0.01};main(args:[]string){pl("=== Temperature Conversion Table ===");pf("%-12s %-12s %-12s%n","Celsius","Fahrenheit","Kelvin");pl("-".repeat(36));celsiusValues:=[]float64{-40,-20,0,20,37,100};for _,c:=range celsiusValues{t:=Temperature(c,Unit.CELSIUS);f:=t.convertTo(Unit.FAHRENHEIT);k:=t.convertTo(Unit.KELVIN);pf("%-12s %-12s %-12s%n",t,f,k)};pl();pl("=== Verification Tests ===");t1:=Temperature(0,Unit.CELSIUS).convertTo(Unit.FAHRENHEIT);pl("0C -> F: "+t1+" "+(if(approxEqual(t1.value,32.0),"PASS","FAIL")));t2:=Temperature(100,Unit.CELSIUS).convertTo(Unit.FAHRENHEIT);pl("100C -> F: "+t2+" "+(if(approxEqual(t2.value,212.0),"PASS","FAIL")));t3:=Temperature(0,Unit.CELSIUS).convertTo(Unit.KELVIN);pl("0C -> K: "+t3+" "+(if(approxEqual(t3.value,273.15),"PASS","FAIL")));t4:=Temperature(212,Unit.FAHRENHEIT).convertTo(Unit.CELSIUS);pl("212F -> C: "+t4+" "+(if(approxEqual(t4.value,100.0),"PASS","FAIL")));t5:=Temperature(373.15,Unit.KELVIN).convertTo(Unit.CELSIUS);pl("373.15K -> C: "+t5+" "+(if(approxEqual(t5.value,100.0),"PASS","FAIL")));t6:=Temperature(37,Unit.CELSIUS).convertTo(Unit.FAHRENHEIT).convertTo(Unit.KELVIN).convertTo(Unit.CELSIUS);pl("Round-trip 37C: "+t6+" "+(if(approxEqual(t6.value,37.0),"PASS","FAIL")));t7:=Temperature(-40,Unit.CELSIUS).convertTo(Unit.FAHRENHEIT);pl("-40C -> F: "+t7+" "+(if(approxEqual(t7.value,-40.0),"PASS","FAIL")))};const(CELSIUS;FAHRENHEIT;KELVIN);@class Temperature{value:float64;unit:Unit;init(value:float64,unit:Unit){this.value=value;this.unit=unit};toCelsius()->float64{^(unit)};convertTo(target:Unit)->Temperature{celsius:=toCelsius();result:=(target);^Temperature(result,target)};toString()->string{symbol:=(unit);^sf("%.2f %s",value,symbol)}}