!v2;findMax(arr:[]int)->int{max:=arr[0];for i:=1;i<len(arr);i++{if (arr[i]>max){max=arr[i]}};^max};findMin(arr:[]int)->int{min:=arr[0];for i:=1;i<len(arr);i++{if (arr[i]<min){min=arr[i]}};^min};findMaxMin(arr:[]int)->[]int{if (arr==nil||len(arr)==0){throw IllegalArgumentException("Array must not be empty")};^[]int{findMax(arr),findMin(arr)}};main(args:[]string){data:=[]int{38,7,102,-4,56,23,0,91,-15,44};result:=findMaxMin(data);pl("Array: [38, 7, 102, -4, 56, 23, 0, 91, -15, 44]");pl("Max: "+result[0]);pl("Min: "+result[1]);pl("Max correct: "+(if(result[0]==102,"PASS","FAIL")));pl("Min correct: "+(if(result[1]==-15,"PASS","FAIL")));single:=[]int{42};r2:=findMaxMin(single);pl("Single element max==min: "+(if(r2[0]==42&&r2[1]==42,"PASS","FAIL")));try{findMaxMin(make([]int,0));pl("Empty array exception: FAIL")}catch(e:IllegalArgumentException){pl("Empty array exception: PASS")}}