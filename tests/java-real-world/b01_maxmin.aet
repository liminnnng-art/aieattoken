!java-v1;findMax(int[] arr)->int{max:=arr[0];for(i:=1;i<ln(arr);i++){if arr[i]>max{max=arr[i]}};max};findMin(int[] arr)->int{min:=arr[0];for(i:=1;i<ln(arr);i++){if arr[i]<min{min=arr[i]}};min};findMaxMin(int[] arr)->int[]{if arr==nil||ln(arr)==0{throw IllegalArgumentException("Array must not be empty")};new int[]{findMax(arr),findMin(arr)}};main(){data:=new int[]{38,7,102,-4,56,23,0,91,-15,44};result:=findMaxMin(data);pl("Array: [38, 7, 102, -4, 56, 23, 0, 91, -15, 44]");pl("Max: "+result[0]);pl("Min: "+result[1]);pl("Max correct: "+(result[0]==102?"PASS":"FAIL"));pl("Min correct: "+(result[1]==-15?"PASS":"FAIL"));single:=new int[]{42};r2:=findMaxMin(single);pl("Single element max==min: "+(r2[0]==42&&r2[1]==42?"PASS":"FAIL"));tc{findMaxMin(new int[0]);pl("Empty array exception: FAIL")}(IllegalArgumentException e){pl("Empty array exception: PASS")}}