!v3;countWords(text:string)->map[string]Integer{counts:=mk(mp[string]_in);words:=text.toLowerCase().split("\s+");for _,word:=rng words{word=word.replaceAll("[^a-z]","");if (!word.isEmpty()){counts.put(word,counts.getOrDefault(word,0)+1)}};^counts};main(args:[]string){text:="the cat sat on the mat and the cat liked the mat";counts:=countWords(text);pl("Text: ""+text+""");pl("Word frequencies (sorted):");counts.entrySet().stream().sorted(Map.Entry.comparingByValue().reversed().thenComparing(Map.Entry.comparingByKey())).forEach({e|pl("  "+e.getKey()+": "+e.getValue())});pl("'the' count correct: "+(_t(counts.get("the")==4,"PASS","FAIL")));pl("'cat' count correct: "+(_t(counts.get("cat")==2,"PASS","FAIL")));pl("'sat' count correct: "+(_t(counts.get("sat")==1,"PASS","FAIL")));pl("Total unique words: "+counts.size());pl("Unique count correct: "+(_t(counts.size()==7,"PASS","FAIL")))}