=== Entries Test ===");eStore:=KVStore();eStore.put("x","10");eStore.put("y","20");entries:=eStore.entries();check("Entries size",entries.size()==2);check("First entry key","x".equals(entries.get(0).getKey()));pf("%n=== Results: %d passed, %d failed ===%n",passed,failed)};var passed:int=0;var failed:int=0;@class KVStore{store:map[K]V;opCount:int;put(key:K,value:V){Objects.requireNonNull(key,"Key must not be null");store.put(key,value);opCount++};get(key:K)->*V{^Optional.ofNullable(store.get(key))};has(key:K)->bool{^store.containsKey(key)};delete(key:K)->bool{existed:=store.containsKey(key);store.remove(key);if (existed){opCount++};^existed};size()->int{^store.size()};getOpCount()->int{^opCount};keys()->map[K]bool{^Collections.unmodifiableSet(store.keySet())};values()->Collection{^Collections.unmodifiableCollection(store.values())};entries()->[]Map.Entry{^mk([]_in)};clear(){store.clear();opCount++};toString()->string{sb:=Sb("KVStore{");i:=0;for _,entry:=rng store.entrySet(){if (i>0){sb.apd(", ")};sb.apd(entry.getKey()).apd("=").apd(entry.getValue());i++};sb.apd("}");^sb.function toString() { [native code] }()}}