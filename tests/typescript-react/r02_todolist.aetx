!tsx1
@Todo{id:n;text:s;done:b};:=TodoList=()=>{:=[todos,setTodos]=useState([]),[input,setInput]=useState(""),addTodo=()=>{if input.trim()===""{^};:=newTodo={id:Date.now(),text:input,done:false};setTodos([...todos,newTodo]);setInput("")},toggleTodo=(id)=>{setTodos(todos.map(t=>t.id===id?{...t,done:!t.done}:t))},removeTodo=(id)=>{setTodos(todos.filter(t=>t.id!==id))};^<div><input value={input} onChange={e=>setInput(e.target.value)}/><button onClick={addTodo}>Add</button><ul>{todos.map(t=><li key={t.id}><span onClick={()=>toggleTodo(t.id)}>{t.text}</span><button onClick={()=>removeTodo(t.id)}>X</button></li>)}</ul></div>};+d TodoList
