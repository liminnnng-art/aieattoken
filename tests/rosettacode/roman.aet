!go-v2;toRoman(n){values:=[]int{1000,900,500,400,100,90,50,40,10,9,5,4,1};symbols:=[]string{"M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"};result:="";for i,v:=range values{for n>=v{result+=symbols[i];n-=v}};result};main(){tests:=[]int{1990,2008,1666};for _,n:=range tests{pf("%d = %s\n",n,toRoman(n))}}