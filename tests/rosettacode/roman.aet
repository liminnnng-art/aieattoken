toRoman(n){vals:=[]int{1000,900,500,400,100,90,50,40,10,9,5,4,1};syms:=[]string{"M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"};result:="";for i:=0..ln(vals){for n>=vals[i]{result+=syms[i];n-=vals[i]}};result};main(){nums:=[]int{1990,2008,1666};for _,n:=rng nums{pf("%d = %s\n",n,toRoman(n))}}