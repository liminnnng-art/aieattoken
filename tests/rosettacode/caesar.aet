a(s,shift){result:=mk([]byte,#s);for i:=0..#s{c:=s[i];switch{case c>='A'&&c<='Z':result[i]=byte((int(c-'A')+shift)%26)+'A';case c>='a'&&c<='z':result[i]=byte((int(c-'a')+shift)%26)+'a';default:result[i]=c}};string(result)};d(s,shift){a(s,26-shift)};main(){text:="The quick brown fox jumps over the lazy dog";shift:=13;b:=a(text,shift);e:=d(b,shift);pf("Original:  %s\n",text);pf("Encrypted: %s\n",b);pf("Decrypted: %s\n",e)}