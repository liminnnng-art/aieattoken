!go-v2;caesarEncrypt(s,shift){result:=mk([]byte,#s);for i:=0..#s{c:=s[i];switch{case c>='A'&&c<='Z':result[i]=byte((int(c-'A')+shift)%26)+'A';case c>='a'&&c<='z':result[i]=byte((int(c-'a')+shift)%26)+'a';default:result[i]=c}};string(result)};caesarDecrypt(s:string,shift:int)->string{^caesarEncrypt(s,26-shift)};main(){text:="The quick brown fox jumps over the lazy dog";shift:=13;encrypted:=caesarEncrypt(text,shift);decrypted:=caesarDecrypt(encrypted,shift);pf("Original:  %s\n",text);pf("Encrypted: %s\n",encrypted);pf("Decrypted: %s\n",decrypted)}