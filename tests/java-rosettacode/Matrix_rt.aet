!java-v1;multiply(int[][] a,int[][] b)->int[][]{rows:=ln(a);cols:=ln(b[0]);inner:=ln(b);result:=new int[rows][cols];for(i:=0;i<rows;i++){for(j:=0;j<cols;j++){for(k:=0;k<inner;k++){result[i][j]+=a[i][k]*b[k][j]}}};result};printMatrix(String label,int[][] m){pl(label);for(row:m){pf("  [%d, %d]%n",row[0],row[1])}};main(){a:=new []int[]{new int[]{1,2},new int[]{3,4}};b:=new []int[]{new int[]{5,6},new int[]{7,8}};c:=multiply(a,b);printMatrix("A:",a);printMatrix("B:",b);printMatrix("A * B:",c)}