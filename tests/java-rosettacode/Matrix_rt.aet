!v3;multiply(a:[][]int,b:[][]int)->[][]int{rows:=ln(a);cols:=ln(b[0]);inner:=ln(b);result:=mk([][]int,rows,cols);for i:=0;i<rows;i++{for j:=0;j<cols;j++{for k:=0;k<inner;k++{result[i][j]+=a[i][k]*b[k][j]}}};^result};printMatrix(label:string,m:[][]int){pl(label);for _,row:=rng m{pf("  [%d, %d]%n",row[0],row[1])}};main(args:[]string){a:=[][]int{[]_in{1,2},[]_in{3,4}};b:=[][]int{[]_in{5,6},[]_in{7,8}};c:=multiply(a,b);printMatrix("A:",a);printMatrix("B:",b);printMatrix("A * B:",c)}