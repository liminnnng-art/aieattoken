!java-v1;luhnCheck(String number)->boolean{sum:=0;alternate:=false;for(i:=ln(number)-1;i>=0;i--){digit:=number.charAt(i)-'0';if alternate{digit*=2;if digit>9{digit-=9}};sum+=digit;alternate=!alternate};sum%10==0};main(){testNumbers:=new String[]{"49927398716","49927398717","1234567812345678","1234567812345670"};for(num:testNumbers){pf("%s: %s%n",num,luhnCheck(num)?"valid":"invalid")}}