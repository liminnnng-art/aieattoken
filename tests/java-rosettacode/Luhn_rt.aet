!v3;luhnCheck(number:string)->bool{sum:=0;alternate:=false;for i:=ln(number)-1;i>=0;i--{digit:=number.charAt(i)-'0';if (alternate){digit*=2;if (digit>9){digit-=9}};sum+=digit;alternate=!alternate};^sum%10==0};main(args:[]string){testNumbers:=[]string{"49927398716","49927398717","1234567812345678","1234567812345670"};for _,num:=rng testNumbers{pf("%s: %s%n",num,iif(luhnCheck(num),"valid","invalid"))}}