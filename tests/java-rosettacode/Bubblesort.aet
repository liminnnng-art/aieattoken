!v3;bubbleSort(arr:[]int){n:=ln(arr);var swapped:bool;for i:=0;i<n-1;i++{swapped=false;for j:=0;j<n-1-i;j++{if (arr[j]>arr[j+1]){temp:=arr[j];arr[j]=arr[j+1];arr[j+1]=temp;swapped=true}};if (!swapped){break}}};main(args:[]string){data:=[]int{5,3,8,6,2,7,1,4};pl("Before: "+Arrays.function toString() { [native code] }(data));bubbleSort(data);pl("After:  "+Arrays.function toString() { [native code] }(data))}