!v3;toRoman(number:int)->string{sb:=Sb();for i:=0;i<ln(VALUES);i++{for (number>=VALUES[i]){sb.apd(SYMBOLS[i]);number-=VALUES[i]}};^sb.function toString() { [native code] }()};main(args:[]string){testValues:=[]int{1,4,9,14,42,99,2024};for _,v:=rng testValues{pf("%4d = %s%n",v,toRoman(v))}};var VALUES:[]int=[]_in{1000,900,500,400,100,90,50,40,10,9,5,4,1};var SYMBOLS:[]string=[]_in{"M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"}