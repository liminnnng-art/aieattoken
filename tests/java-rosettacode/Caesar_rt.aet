!v3;encrypt(text:string,shift:int)->string{sb:=Sb();for _,c:=rng text.toCharArray(){if (Character.isUpperCase(c)){sb.append(rune(('A'+(c-'A'+shift)%26)))}else if (Character.isLowerCase(c)){sb.append(rune(('a'+(c-'a'+shift)%26)))}else{sb.append(c)}};^sb.toString()};decrypt(text:string,shift:int)->string{^encrypt(text,26-shift)};main(args:[]string){plaintext:="The quick brown fox";shift:=11;encrypted:=encrypt(plaintext,shift);decrypted:=decrypt(encrypted,shift);pl("Plain:     "+plaintext);pl("Encrypted: "+encrypted);pl("Decrypted: "+decrypted)}