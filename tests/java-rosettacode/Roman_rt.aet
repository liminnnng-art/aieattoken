!java-v1;toRoman(int number)->String{sb:=Sb();for(i:=0;i<ln(VALUES);i++){while number>=VALUES[i]{sb.apd(SYMBOLS[i]);number-=VALUES[i]}};sb.toString()};main(){testValues:=new int[]{1,4,9,14,42,99,2024};for(v:testValues){pf("%4d = %s%n",v,toRoman(v))}};var VALUES=new int[]{1000,900,500,400,100,90,50,40,10,9,5,4,1};var SYMBOLS=new String[]{"M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"}