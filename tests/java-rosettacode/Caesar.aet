!java-v1;encrypt(String text,int shift)->String{sb:=Sb();for(c:text.toCharArray()){if Cu(c){sb.apd((char)('A'+(c-'A'+shift)%26))}else if Lo(c){sb.apd((char)('a'+(c-'a'+shift)%26))}else{sb.apd(c)}};sb.toString()};decrypt(String text,int shift)->String{encrypt(text,26-shift)};main(){plaintext:="The quick brown fox";shift:=11;encrypted:=encrypt(plaintext,shift);decrypted:=decrypt(encrypted,shift);pl("Plain:     "+plaintext);pl("Encrypted: "+encrypted);pl("Decrypted: "+decrypted)}