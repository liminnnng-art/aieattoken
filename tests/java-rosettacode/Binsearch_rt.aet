!java-v1;binarySearch(int[] arr,int target)->int{lo:=0;hi:=ln(arr)-1;while lo<=hi{mid:=lo+(hi-lo)/2;if arr[mid]==target{^mid}else if arr[mid]<target{lo=mid+1}else{hi=mid-1}};-1};main(){sorted:=new int[]{1,3,5,7,9,11,13};targets:=new int[]{7,8};for(t:targets){idx:=binarySearch(sorted,t);if idx>=0{pf("%d found at index %d%n",t,idx)}else{pf("%d not found%n",t)}}}