interface Post {
  id: number;
  title: string;
  content: string;
  author: string;
}

interface ApiContext {
  db: Map<number, Post>;
  log: (msg) => void;
}

class PostRepository {
  constructor(private ctx: ApiContext) {}
  async findAll() {
    this.ctx.log("findAll");
    return Array.from(this.ctx.db.values());
  }
  async findById(id) {
    this.ctx.log("findById " + id);
    return this.ctx.db.get(id);
  }
  async create(data) {
    const id = this.ctx.db.size + 1, post = { ...data, id };
    this.ctx.db.set(id, post);
    this.ctx.log("created " + id);
    return post;
  }
  async update(id, data) {
    const existing = this.ctx.db.get(id);
    if (!existing) {
      return null;
    }
    const updated = { ...existing, ...data };
    this.ctx.db.set(id, updated);
    return updated;
  }
  async delete(id) {
    return this.ctx.db.delete(id);
  }
}

export default PostRepository;
