!ts1
@User{id:n;name:s;email:s;createdAt:s};@UserService{-users:User[]=[];-!filePath:s;init(dataDir){.filePath=pj(dataDir,"users.json");.load()};-load(){if ef(.filePath){:=data=rf(.filePath,"utf-8");.users=jl(data)}};-save(){wf(.filePath,jd(.users,null,2))};findById(id){^.users.find(u=>u.id===id)};findByEmail(email){^.users.find(u=>u.email===email)};create(name,email){:=newUser={id:.users.length+1,name,email,createdAt:new Date().toISOString()};.users.push(newUser);.save();^newUser};delete(id){:=idx=.users.findIndex(u=>u.id===id);if idx===-1{^false};.users.splice(idx,1);.save();^true};list(){^[....users]}};+d UserService
