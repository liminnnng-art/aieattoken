!ts1
@Post{id:n;title:s;content:s;author:s};@ApiContext{db:Map<n,Post>;log:(msg)->v};@PostRepository{init(-ctx:ApiContext){};a findAll(){.ctx.log("findAll");^Af(.ctx.db.values())};a findById(id){.ctx.log("findById "+id);^.ctx.db.get(id)};a create(data){:=id=.ctx.db.size+1;:=post={...data,id};.ctx.db.set(id,post);.ctx.log("created "+id);^post};a update(id,data){:=existing=.ctx.db.get(id);if !existing{^null};:=updated={...existing,...data};.ctx.db.set(id,updated);^updated};a delete(id){^.ctx.db.delete(id)}};+d PostRepository
