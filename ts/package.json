{
  "name": "aieattoken",
  "version": "0.1.0",
  "description": "AI-native token compression for Go, Java, and Python. Reduces LLM token usage by 30-55%.",
  "main": "dist/cli.js",
  "bin": {
    "aet": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "postinstall": "node scripts/build-go-parser.js",
    "aet": "node dist/cli.js",
    "test": "node dist/cli.js stats ../tests/rosettacode/fibonacci.go"
  },
  "files": [
    "dist/",
    "go-parser/main.go",
    "go-parser/go.mod",
    "java-parser/ASTDumper.java",
    "python-parser/ast_dumper.py",
    "stdlib-aliases.json",
    "stdlib-aliases-java.json",
    "stdlib-aliases-python.json",
    "popular-aliases-python.json",
    "scripts/",
    "README.md"
  ],
  "keywords": [
    "ai",
    "llm",
    "token-compression",
    "tokens",
    "go",
    "golang",
    "java",
    "python",
    "transpiler",
    "compression",
    "tokenizer",
    "gpt",
    "claude"
  ],
  "author": "Ez",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "chevrotain": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
