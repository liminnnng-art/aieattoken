{
  "name": "aieattoken",
  "version": "0.1.0",
  "description": "Compress Go code into AI-native format — 39% fewer tokens, same compiled performance",
  "main": "dist/cli.js",
  "bin": {
    "aet": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "postinstall": "node scripts/build-go-parser.js",
    "aet": "node dist/cli.js",
    "test": "node dist/cli.js stats ../tests/rosettacode/fibonacci.go"
  },
  "files": [
    "dist/",
    "go-parser/main.go",
    "go-parser/go.mod",
    "stdlib-aliases.json",
    "scripts/",
    "README.md"
  ],
  "keywords": [
    "ai",
    "llm",
    "tokens",
    "go",
    "golang",
    "transpiler",
    "compression",
    "tokenizer",
    "gpt",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/aieattoken"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "chevrotain": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
